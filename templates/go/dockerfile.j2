# Stage 1: Build
FROM {{ build_image }} AS builder

WORKDIR /app

# Cache go modules
COPY go.mod go.sum* ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o app .

# Stage 2: Minimal runtime
FROM scratch

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /app/app /app

EXPOSE {{ port }}

ENTRYPOINT ["/app"]
