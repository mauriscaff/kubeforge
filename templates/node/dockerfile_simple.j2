FROM {{ base_image }}

WORKDIR /app

# Create non-root user before any COPY
RUN addgroup --system appgroup && adduser --system --ingroup appgroup {{ user }}

# Install dependencies (layer cache optimization)
COPY package*.json ./
RUN {{ package_manager }} install --frozen-lockfile

# Copy source with correct ownership from the start
COPY --chown={{ user }}:appgroup . .

EXPOSE {{ port }}

USER {{ user }}

CMD [{{ start_command | split | map('tojson') | join(', ') }}]
