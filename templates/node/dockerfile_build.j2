# Stage 1: Build
FROM {{ base_image }} AS builder

WORKDIR /app

RUN addgroup --system appgroup && adduser --system --ingroup appgroup {{ user }}

COPY package*.json ./
RUN {{ package_manager }} install --frozen-lockfile

COPY --chown={{ user }}:appgroup . .
RUN {{ build_command }}

# Stage 2: Production
FROM {{ base_image }} AS runner

WORKDIR /app

ENV NODE_ENV=production

RUN addgroup --system appgroup && adduser --system --ingroup appgroup {{ user }}

COPY --from=builder /app/package*.json ./
RUN {{ package_manager }} install --frozen-lockfile --production

{% if framework == "nextjs" %}
COPY --chown={{ user }}:appgroup --from=builder /app/.next ./.next
COPY --chown={{ user }}:appgroup --from=builder /app/public ./public
{% elif framework == "nestjs" %}
COPY --chown={{ user }}:appgroup --from=builder /app/dist ./dist
{% else %}
COPY --chown={{ user }}:appgroup --from=builder /app/dist ./dist
{% endif %}

EXPOSE {{ port }}

USER {{ user }}

CMD [{{ start_command | split | map('tojson') | join(', ') }}]
