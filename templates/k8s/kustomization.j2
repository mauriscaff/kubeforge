apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{ namespace }}

resources:
  - deployment.yaml
  - service.yaml
{% if config_vars %}
  - configmap.yaml
{% endif %}
{% if secret_vars %}
  - secret.yaml
{% endif %}
{% if generate_hpa %}
  - hpa.yaml
{% endif %}

commonLabels:
  app: {{ app_name }}
  managed-by: kubeforge
