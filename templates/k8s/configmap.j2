apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ app_name }}-config
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
    app.kubernetes.io/component: backend
    app.kubernetes.io/managed-by: kubeforge
data:
{% for key, value in config_vars.items() %}
  {{ key }}: "{{ value }}"
{% endfor %}
