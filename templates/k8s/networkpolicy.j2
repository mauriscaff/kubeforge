apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ app_name }}-netpol
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
    app.kubernetes.io/component: backend
    app.kubernetes.io/managed-by: kubeforge
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: {{ app_name }}
  policyTypes:
    - Ingress
    - Egress
  ingress:
    - ports:
        - protocol: TCP
          port: {{ port }}
  egress:
    - {}
