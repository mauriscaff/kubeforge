# Stage 1: Build
FROM {{ build_image }} AS builder

WORKDIR /app

{% if build_tool == "maven" %}
COPY pom.xml ./
COPY src ./src
RUN mvn package -DskipTests
{% else %}
COPY build.gradle* settings.gradle* gradlew ./
COPY gradle ./gradle
COPY src ./src
RUN chmod +x gradlew && ./gradlew build -x test
{% endif %}

# Stage 2: Runtime
FROM {{ base_image }}

# tini como PID 1 para tratamento correto de sinais e evitar processos zumbi
RUN apk add --no-cache tini

RUN addgroup --system appgroup && adduser --system --ingroup appgroup {{ user }}

WORKDIR /app

{% if build_tool == "maven" %}
COPY --chown={{ user }}:appgroup --from=builder /app/target/*.jar app.jar
{% else %}
COPY --chown={{ user }}:appgroup --from=builder /app/build/libs/*.jar app.jar
{% endif %}

EXPOSE {{ port }}

USER {{ user }}

ENTRYPOINT ["/sbin/tini", "--", "java", "-jar", "app.jar"]
